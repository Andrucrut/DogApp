# Async SQLAlchemy → нужен postgresql+asyncpg://… Можно задать MONOLITH_DATABASE_URL или обычную DATABASE_URL
# (как у linked Postgres на Render) — монолит сам добавит +asyncpg для postgres:// и postgresql://.
MONOLITH_DATABASE_URL=postgresql+asyncpg://dogapp:dogapp@localhost:55432/dogapp_monolith
MONOLITH_BASE_URL=http://127.0.0.1:9000
MONOLITH_SECRET_KEY=same-as-account-service-for-jwt
MONOLITH_INTERNAL_API_TOKEN=shared-secret-for-internal-calls
