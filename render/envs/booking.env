# booking_service
# SECRET_KEY = тот же, что в account (для JWT)
# INTERNAL_API_TOKEN = тот же shared token

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/booking_db
SECRET_KEY=PLACEHOLDER_SAME_AS_ACCOUNT_SECRET_KEY
INTERNAL_API_TOKEN=PLACEHOLDER_SHARED_INTERNAL_TOKEN
ACCOUNT_SERVICE_URL=https://YOUR-ACCOUNT-SERVICE.onrender.com
NOTIFICATION_SERVICE_URL=https://YOUR-NOTIFICATION-SERVICE.onrender.com
PAYMENT_SERVICE_URL=https://YOUR-PAYMENT-SERVICE.onrender.com
ALGORITHM=HS256
GEOCODER_PROVIDER=nominatim
HTTP_TIMEOUT_SECONDS=5
