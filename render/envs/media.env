# media_service
# SECRET_KEY = тот же, что в account
# Файлы на диске Render эфемерные — при рестарте могут пропасть; для прод лучше S3 и т.п.

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/media_db
SECRET_KEY=PLACEHOLDER_SAME_AS_ACCOUNT_SECRET_KEY
ALGORITHM=HS256
UPLOAD_DIR=./data/media_uploads
MAX_UPLOAD_BYTES=10485760
