# account_service — импорт в Render → Environment
# DATABASE_URL: postgresql+asyncpg://... из вашей PostgreSQL (см. RENDER_SETUP.txt)

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/account_db
SECRET_KEY=PLACEHOLDER_GENERATE_LONG_RANDOM_STRING
INTERNAL_API_TOKEN=PLACEHOLDER_SHARED_INTERNAL_TOKEN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=5
